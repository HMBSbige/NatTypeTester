             x:Class="NatTypeTester.Views.App">
    <Application.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
